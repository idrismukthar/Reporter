<!DOCTYPE html>
<html lang="en">
<head>
    <title>Control Tower | Results Viewer</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --card-border: rgba(255, 255, 255, 0.1);
            --primary: #8b5cf6;
            --primary-hover: #7c3aed;
            --accent: #10b981;
            --danger: #ef4444;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
        }
        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            min-height: 100vh;
        }
        .container { max-width: 1200px; margin: 0 auto; }
        
        .glass {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--card-border);
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        .admin-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 20px 30px; margin-bottom: 30px;
        }
        .logo-area { display: flex; align-items: center; gap: 20px; }
        .logo-area img { height: 50px; border-radius: 8px; }
        .logo-area h1 { font-size: 28px; font-weight: 700; margin: 0; letter-spacing: 1px; }
        .logo-area span { color: var(--primary); }
        
        .btn {
            padding: 10px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; 
            transition: all 0.3s ease; text-decoration: none; border: 1px solid transparent;
            cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
        }
        .btn-outline {
            background: rgba(139, 92, 246, 0.1); color: var(--primary);
            border-color: rgba(139, 92, 246, 0.3);
        }
        .btn-outline:hover { background: var(--primary); color: white; transform: translateY(-2px); }
        
        .btn-action {
            background: rgba(16, 185, 129, 0.15); color: var(--accent);
            border: 1px solid rgba(16, 185, 129, 0.3); padding: 8px 16px; font-size: 13px;
        }
        .btn-action:hover { background: var(--accent); color: white; transform: translateY(-2px); }

        .filter-bar {
            padding: 20px; display: flex; gap: 20px; margin-bottom: 30px; align-items: center; flex-wrap: wrap;
        }
        select, button.apply-btn {
            background: rgba(15, 23, 42, 0.6); color: white; border: 1px solid var(--card-border);
            padding: 12px 16px; border-radius: 8px; font-size: 14px; outline: none; transition: 0.2s;
        }
        select:focus { border-color: var(--primary); }
        button.apply-btn { 
            background: var(--primary); border: none; font-weight: 600; cursor: pointer; 
            padding: 12px 24px; box-shadow: 0 4px 14px 0 rgba(139, 92, 246, 0.39);
        }
        button.apply-btn:hover { background: var(--primary-hover); transform: translateY(-2px); }
        
        .table-card { padding: 24px; overflow-x: auto; margin-bottom: 30px; }
        h4.card-title { margin: 0 0 20px 0; font-size: 18px; font-weight: 600; color: white; }
        
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; color: var(--text-muted); font-size: 13px; font-weight: 600; padding: 15px 10px; border-bottom: 1px solid var(--card-border); text-transform: uppercase; }
        td { padding: 15px 10px; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 14px; vertical-align: middle; }
        tr:hover td { background: rgba(255,255,255,0.02); }
        
        .student-name { color: white; font-weight: 600; }
        .student-adm { color: var(--text-muted); font-size: 12px; }

    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="admin-header glass">
            <div class="logo-area">
                <img src="/img/tlmps_llogo.png" alt="Logo" onerror="this.src='https://via.placeholder.com/50'">
                <h1>Results <span>Viewer</span></h1>
            </div>
            <div style="display: flex; gap: 15px;">
                <a href="/admin/dashboard" class="btn btn-outline">⬅ Back to Dashboard</a>
            </div>
        </div>

        <!-- Filters -->
        <form class="filter-bar glass" method="GET" action="/admin/results">
            <select name="session">
                <option value="2025_and_2026" <%= session === '2025_and_2026' ? 'selected' : '' %>>Session: 2025/2026</option>
                <option value="2026_and_2027" <%= session === '2026_and_2027' ? 'selected' : '' %>>Session: 2026/2027</option>
            </select>
            <select name="term">
                <option value="First_term" <%= term === 'First_term' ? 'selected' : '' %>>First Term</option>
                <option value="Second_term" <%= term === 'Second_term' ? 'selected' : '' %>>Second Term</option>
                <option value="Third_term" <%= term === 'Third_term' ? 'selected' : '' %>>Third Term</option>
            </select>
            <select name="class">
                <option value="JSS1" <%= className === 'JSS1' ? 'selected' : '' %>>JSS 1</option>
                <option value="JSS2" <%= className === 'JSS2' ? 'selected' : '' %>>JSS 2</option>
                <option value="JSS3" <%= className === 'JSS3' ? 'selected' : '' %>>JSS 3</option>
                <option value="SSS1" <%= className === 'SSS1' ? 'selected' : '' %>>SSS 1</option>
                <option value="SSS2" <%= className === 'SSS2' ? 'selected' : '' %>>SSS 2</option>
                <option value="SSS3" <%= className === 'SSS3' ? 'selected' : '' %>>SSS 3</option>
            </select>
            <button type="submit" class="apply-btn">Load Students</button>
        </form>

        <!-- Students List -->
        <div class="table-card glass">
            <h4 class="card-title" style="color: var(--accent);">📋 <%= className %> Students - <%= term.replace('_', ' ') %></h4>
            <table>
                <thead>
                    <tr>
                        <th>Admission No.</th>
                        <th>Student Name</th>
                        <th>Gender</th>
                        <th style="text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (students && students.length > 0) { %>
                        <% students.forEach(s => { %>
                            <tr>
                                <td class="student-adm"><%= s.admission_no %></td>
                                <td class="student-name">
                                    <%= (s.surname || '') + ' ' + (s.m_name || '') + ' ' + (s.l_name || '') %>
                                </td>
                                <td><%= s.gender || 'N/A' %></td>
                                <td style="text-align: right;">
                                    <a href="/admin/view-result/<%= session %>/<%= term %>/<%= s.admission_no %>" 
                                       target="_blank" 
                                       class="btn btn-action">
                                       👁️ View & Download Result
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 30px;">
                                <div style="color: var(--text-muted); margin-bottom: 10px; font-size: 24px;">📭</div>
                                No students found for this selection.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
